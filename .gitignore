# Personal notes (interview prep, scratch) — never committed
/notes/

# Raw un-sanitized collection export — kept local; only the sanitized fixture is committed
seed-data/*.raw.csv

# Real capture fixtures from the user's own photos (show hand/home) — kept local, off the public repo.
# The committed funko_box.png (stock) + the real-OCR data embedded in BoxLayoutParserTest cover the cascade.
# Week-11 eval: personal box photos (phone-shot .jpg/.jpeg/.heic) are gitignored; the committed
# photo_fixtures.tsv manifest holds the LABELS (commit the coverage, not the private images). funko_box.png
# (stock .png) stays committed as the one exception. Drop new box photos in androidTest/assets/ by the name
# referenced in the manifest — they will be ignored automatically.
/app/src/androidTest/assets/freddy32_*.jpg
/app/src/androidTest/assets/*.jpg
/app/src/androidTest/assets/*.jpeg
/app/src/androidTest/assets/*.heic

# Claude local settings (machine-specific)
.claude/settings.local.json

# Firebase config — excluded by default for a public repo (contains project/app ids + client API key).
# Remove this line if you want the repo buildable on clone without supplying your own.
/app/google-services.json

# eBay Browse API credentials (production App ID / Cert ID) — secrets, kept local, never committed.
# Copy ebay.properties.example → ebay.properties and fill in; Gradle reads it into BuildConfig.
/ebay.properties

# ExecuTorch harness (tools/executorch-harness/) is a standalone Gradle project;
# the root /build rule is anchored, so ignore its build output explicitly.
/tools/executorch-harness/build/
/tools/executorch-harness/app/build/
# Quantized model artifacts are 86 MiB – 1.7 GiB — never committed; rebuild from export/.
*.pte
