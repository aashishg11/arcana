<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Dark-first: window background matches the Arcana bg so there's no light flash before Compose draws. -->
    <style name="Theme.Arcana" parent="android:Theme.Material.NoActionBar">
        <item name="android:windowBackground">@color/arcana_bg</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>
</resources>
